run = "npm run dev:full"
entrypoint = "src/App.jsx"
modules = ["nodejs-20", "python-3.11"]

[deployment]
deploymentTarget = "static"
build = ["sh", "-c", "npm install && npm run build"]
publicDir = "dist"

[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:full"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[userenv]

